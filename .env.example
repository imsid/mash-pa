# Copy to .env. Do not quote values — python-dotenv treats quotes as literal.

# Required: LLM provider for all PA agents.
ANTHROPIC_API_KEY=

# Optional: GitHub personal access token for the GitHub MCP server.
# Powers the github-digest workflow (read-only). Omit to run without GitHub
# tools; the workflow then explains how to configure itself.
GITHUB_MCP_PAT=

# Optional: Parallel AI key for the web_search/web_fetch tools used by the
# digest agents. Omit to use the free anonymous tier (lower rate limits).
PARALLEL_API_KEY=

# Optional: connector key for following YouTube creators. Used ONLY to resolve a
# @handle / channel name to its channel id when subscribing — steady-state
# polling is pure RSS and needs no key. Without it you can still follow a channel
# by its raw UC… id or /channel/UC… URL.
#
# Podcasts need no key at all: shows resolve to their RSS feed via Apple Podcasts
# (the iTunes Search API), and you can always follow a podcast by its RSS URL.
YOUTUBE_API_KEY=

# Required for the digest agents: they persist topics, bundles, and generated
# digests in this database (the same one the Mash runtime uses). No file
# fallback — the digest store raises if this is unset.
# `docker compose up` sets this inside the container; uncomment it when
# running the host directly on your machine (see CONTRIBUTING.md).
# MASH_DATABASE_URL=postgresql://mash:mash@127.0.0.1:5433/mash_pa
