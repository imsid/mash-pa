# Copy to .env. Do not quote values — python-dotenv treats quotes as literal.

# Required: LLM provider for all PA agents.
ANTHROPIC_API_KEY=

# Optional: GitHub personal access token for the GitHub MCP server.
# Powers the gh-brief agent (read-only). Omit to run without GitHub tools.
GITHUB_MCP_PAT=

# --- Local development only ---
# `docker compose up` sets this inside the container; uncomment it when
# running the host directly on your machine (see CONTRIBUTING.md).
# MASH_DATABASE_URL=postgresql://mash:mash@127.0.0.1:5433/mash_pa
